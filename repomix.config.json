{
    "output": {
        "filePath": "repomix-output.txt",
        "style": "markdown",
        "headerText": "LinkedIn Bot Codebase - Condiviso per analisi AI",
        "instructionFilePath": "",
        "removeComments": false,
        "removeEmptyLines": false,
        "showLineNumbers": true,
        "copyToClipboard": false
    },
    "include": [
        "src/**/*",
        "scripts/**/*",
        "plugins/**/*",
        "n8n/**/*",
        "docs/**/*.md",
        ".github/**/*",
        "package.json",
        "tsconfig.json",
        "tsconfig.frontend.json",
        "eslint.config.js",
        "vitest.config.ts",
        ".env.example",
        "Dockerfile",
        "docker-compose.yml",
        "ecosystem.config.cjs",
        "nginx.conf",
        "README.md",
        "SECURITY.md",
        "THREAT_MODEL.md",
        "GUIDA_ANTI_BAN.md",
        "ROADMAP_V2.1.md"
    ],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            "node_modules/**",
            "dist/**",
            "data/**",
            ".env",
            "*.log",
            "package-lock.json",
            "repomix-output.txt",
            ".git/**"
        ]
    },
    "security": {
        "enableSecurityCheck": true
    }
}