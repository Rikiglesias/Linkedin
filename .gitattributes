# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly LF for source files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.env*  text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.sqlite binary
*.tgz   binary
*.zip   binary
