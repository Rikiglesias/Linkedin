# ============================================================================
# PRESET: PRO — 1 account, AI ibrida + SalesNav + proxy residenziale, ~$160/mese
# ============================================================================
# Uso: copia questo file come `.env` nella root e compila i segreti vuoti
# (ANTHROPIC_API_KEY, PROXY_*, SUPABASE_*, TELEGRAM_*). Le variabili non
# elencate restano sui default di codice (src/config/domains.ts) + profilo
# `production`. Ogni variabile esiste in src/config/ (verificato alla fonte).
# Doc completa e combinazioni VIETATE: docs/PRESET_PROFILES.md
#
# Per chi: outreach B2B serio su 1 account, SalesNav attivo, messaggi curati
# dal cervello cloud (solo purpose no-PII: i dati lead restano su Ollama locale).
# ============================================================================

# --- Profilo base -----------------------------------------------------------
CONFIG_PROFILE=production
TIMEZONE=Europe/Rome
HEADLESS=true
# camoufox = stealth premium (fingerprint Firefox umanizzato, geoip, webrtc block)
# ed esenta dal gap JA3 segnalato dalla validazione con proxy+chromium.
BROWSER_ENGINE=camoufox
CAMOUFOX_GEOIP=true
CAMOUFOX_HUMANIZE=true
CAMOUFOX_BLOCK_WEBRTC=true
BROWSER_LOCALE=it-IT

# --- Orari ---------------------------------------------------------------------
HOUR_START=9
HOUR_END=18

# --- Volumi STANDARD (allineati ai cap compliance del codice) -----------------
SOFT_INVITE_CAP=15
HARD_INVITE_CAP=20
WEEKLY_INVITE_LIMIT=80
SOFT_MSG_CAP=20
HARD_MSG_CAP=35
WEEKLY_MESSAGE_LIMIT=120
PROFILE_VIEW_DAILY_CAP=80
LIKE_DAILY_CAP=30
FOLLOW_DAILY_CAP=15

# --- Crescita / risk (default production già attivi, espliciti i chiave) ------
RAMPUP_ENABLED=true
GROWTH_MODEL_ENABLED=true
ADAPTIVE_CAPS_ENABLED=true
COOLDOWN_ENABLED=true

# --- AI IBRIDA: cervello cloud (no-PII) + Ollama locale (dati lead) -----------
# AI_PROVIDER=auto + ANTHROPIC_API_KEY presente = routing per-purpose:
# ragionamento/contenuti no-PII al cloud, tutto ciò che tocca PII lead a Ollama.
AI_PROVIDER=auto
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5-20251001
OLLAMA_ENDPOINT=http://127.0.0.1:11434
AI_MODEL=llama3.1:8b
AI_PERSONALIZATION_ENABLED=true
AI_SENTIMENT_ENABLED=true
# Auto-reply inbox: tenere OFF finché non si è osservata la qualità per qualche
# settimana (HITL prima dell'automazione completa).
INBOX_AUTO_REPLY_ENABLED=false
AI_ALLOW_REMOTE_ENDPOINT=false
VISION_ALLOW_CLOUD=false

# --- SalesNav ------------------------------------------------------------------
SALESNAV_SYNC_ENABLED=true
# Vuoto = sincronizza tutte le liste scoperte; oppure indica la lista target.
SALESNAV_SYNC_LIST_NAME=
SALESNAV_SYNC_MAX_PAGES=3
SALESNAV_SYNC_INTERVAL_HOURS=24
SALESNAV_SYNC_LIMIT=30

# --- Proxy RESIDENZIALE (sticky, geo-coerente col profilo) ---------------------
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_TYPE_DEFAULT=residential
# Geo-coerenza: ISO country dell'account (mismatch IP/profilo = signal forte)
PROXY_EXPECTED_COUNTRIES=IT
PROXY_QUALITY_CHECK_ENABLED=true
PROXY_MOBILE_PRIORITY_ENABLED=true

# --- DB / sync: SQLite locale + copia Supabase ---------------------------------
SUPABASE_SYNC_ENABLED=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
EVENT_SYNC_SINK=SUPABASE

# --- Messaggi / inviti ----------------------------------------------------------
INVITE_WITH_NOTE=false
WITHDRAW_INVITES_ENABLED=true
PENDING_INVITE_MAX_DAYS=30
# Varianza umana sull'invio messaggi post-accettazione (ore min/max)
MESSAGE_SCHEDULE_MIN_DELAY_HOURS=1
MESSAGE_SCHEDULE_MAX_DELAY_HOURS=12

# --- Monitoring / report ---------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DAILY_REPORT_AUTO_ENABLED=true
DAILY_REPORT_HOUR=20

# --- Dashboard --------------------------------------------------------------------
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_API_KEY=
