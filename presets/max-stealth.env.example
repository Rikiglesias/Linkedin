# ============================================================================
# PRESET: MAX-STEALTH — volumi minimi, varianza massima, proxy mobile, zero cloud
# ============================================================================
# Uso: copia come `.env` e compila i segreti (PROXY mobile, TELEGRAM).
# Le variabili non elencate restano sui default di codice (già difensivi).
# Ogni variabile esiste in src/config/ (verificato alla fonte).
# Doc completa e combinazioni VIETATE: docs/PRESET_PROFILES.md
# Antiban-review: SICURO (nessun valore allenta i default difensivi).
#
# Per chi: account prezioso o già "scottato" (warning/restrizione passata),
# settore ad alto scrutinio, o priorità assoluta = non farsi rilevare.
# Trade-off dichiarato: ~20 inviti/settimana, risultati lenti ma costanti.
# ============================================================================

# --- Profilo base -----------------------------------------------------------
CONFIG_PROFILE=production
TIMEZONE=Europe/Rome
# Headed = massima credibilità (su PC locale). Con camoufox anche headless
# regge bene: metti true solo se giri su macchina senza display.
HEADLESS=false
# camoufox: fingerprint Firefox umanizzato, geoip dal proxy, WebRTC bloccato
BROWSER_ENGINE=camoufox
CAMOUFOX_GEOIP=true
CAMOUFOX_HUMANIZE=true
CAMOUFOX_BLOCK_WEBRTC=true
BROWSER_LOCALE=it-IT

# --- Orari (finestra corta, credibile) -----------------------------------------
HOUR_START=9
HOUR_END=17

# --- Volumi MINIMI -----------------------------------------------------------
SOFT_INVITE_CAP=4
HARD_INVITE_CAP=6
WEEKLY_INVITE_LIMIT=20
SOFT_MSG_CAP=5
HARD_MSG_CAP=8
WEEKLY_MESSAGE_LIMIT=30
PROFILE_VIEW_DAILY_CAP=30
LIKE_DAILY_CAP=10
FOLLOW_DAILY_CAP=5
FOLLOW_UP_DAILY_CAP=5

# --- Soglie risk PIÙ severe dei default --------------------------------------
# (default: warn 0.55 / stop 0.65 — qui si stringe, MAI allargare)
PENDING_RATIO_WARN=0.45
PENDING_RATIO_STOP=0.55
ADAPTIVE_CAPS_PENDING_WARN=0.45
ADAPTIVE_CAPS_PENDING_STOP=0.60
COOLDOWN_WARN_SCORE=60
COOLDOWN_HIGH_SCORE=70
# Circuit breaker più sensibili (default: 8 selector failure, 20 errori/giorno)
MAX_SELECTOR_FAILURES_PER_DAY=4
MAX_RUN_ERRORS_PER_DAY=10
# Ritiro inviti pendenti più aggressivo (default 30 giorni)
WITHDRAW_INVITES_ENABLED=true
PENDING_INVITE_MAX_DAYS=21

# --- Timing: varianza MASSIMA, pause lunghe -----------------------------------
NO_BURST_ENABLED=true
NO_BURST_MIN_DELAY_SEC=20
NO_BURST_MAX_DELAY_SEC=90
NO_BURST_LONG_BREAK_EVERY=5
NO_BURST_LONG_BREAK_MIN_SEC=240
NO_BURST_LONG_BREAK_MAX_SEC=720
INTER_JOB_MIN_DELAY_SEC=90
INTER_JOB_MAX_DELAY_SEC=360
COFFEE_BREAK_MIN_INTERVAL_JOBS=6
COFFEE_BREAK_MAX_INTERVAL_JOBS=10
COFFEE_BREAK_MIN_SEC=240
COFFEE_BREAK_MAX_SEC=600
CONTEXTUAL_PAUSE_MIN_MS=1500
CONTEXTUAL_PAUSE_MAX_MS=6000

# --- Sessioni corte e varie ------------------------------------------------------
SESSION_MEMORY_PROTECTION_MIN_MINUTES=15
SESSION_MEMORY_PROTECTION_MAX_MINUTES=35
# Doppia sessione breve (mattina/pomeriggio con gap pranzo) invece di una lunga
WARMUP_TWO_SESSIONS_PER_DAY=true

# --- Crescita ULTRA-graduale (fasi growth allungate, cap fase ridotti) -------------
GROWTH_BROWSE_ONLY_DAYS=14
GROWTH_SOFT_OUTREACH_DAYS=21
GROWTH_SOFT_OUTREACH_INVITE_MAX=3
GROWTH_MODERATE_GROWTH_INVITE_MAX=6
GROWTH_MODERATE_GROWTH_MESSAGE_MAX=3

# --- Comportamento umano extra ----------------------------------------------------
# Navigazione decoy casuale (feed, ricerche innocue) tra le azioni
RANDOM_ACTIVITY_ENABLED=true
RANDOM_ACTIVITY_PROBABILITY=0.25
RANDOM_ACTIVITY_MAX_ACTIONS=3
# Engagement (like/view) prima del messaggio: pattern più naturale
ENGAGEMENT_BEFORE_MESSAGE_ENABLED=true
# Green mode serale: attività ridotta fuori fascia
GREEN_MODE_ENABLED=true
GREEN_MODE_START_HOUR=21
GREEN_MODE_END_HOUR=7
WEEKEND_POLICY_ENABLED=true

# --- Varianza invio messaggi (post-accettazione) -------------------------------------
MESSAGE_SCHEDULE_MIN_DELAY_HOURS=2
MESSAGE_SCHEDULE_MAX_DELAY_HOURS=24

# --- Inviti: nessuna nota (meno superficie testuale) ----------------------------------
INVITE_WITH_NOTE=false
INVITE_NOTE_MODE=none

# --- Proxy MOBILE (sticky, qualità alta, geo-coerente) ----------------------------------
# Mobile = IP carrier condivisi da migliaia di utenti reali: massima copertura.
# Sticky session (es. Oxylabs 30min), MAI rotation a metà sessione.
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_TYPE_DEFAULT=mobile
PROXY_MOBILE_PRIORITY_ENABLED=true
PROXY_EXPECTED_COUNTRIES=IT
PROXY_QUALITY_CHECK_ENABLED=true
PROXY_QUALITY_MIN_SCORE=70
IP_REPUTATION_MAX_ABUSE_SCORE=10

# --- AI: SOLO locale (zero traffico cloud) ------------------------------------------------
AI_PROVIDER=auto
OLLAMA_ENDPOINT=http://127.0.0.1:11434
AI_MODEL=llama3.1:8b
AI_PERSONALIZATION_ENABLED=true
AI_SENTIMENT_ENABLED=false
INBOX_AUTO_REPLY_ENABLED=false
AI_ALLOW_REMOTE_ENDPOINT=false
VISION_ALLOW_CLOUD=false
VISION_REDACT_SCREENSHOTS=true

# --- Gate difensivi (espliciti, già default) -------------------------------------------------
CHALLENGE_PERSISTENT_GATE=true
MANDATORY_PREFLIGHT_ENABLED=true
ADAPTIVE_CAPS_ENABLED=true
COOLDOWN_ENABLED=true
# Challenge SEMPRE all'umano: l'auto-solve captcha è esso stesso un segnale
CHALLENGE_AUTO_RESOLVE_ENABLED=false

# --- GDPR: retention lead più corta (EU-strict) -------------------------------------------------
GDPR_ANONYMIZE_AFTER_DAYS=90
GDPR_DELETE_AFTER_DAYS=180

# --- DB locale, nessun servizio esterno -------------------------------------------------------
# Flag obbligatorio se avvii con NODE_ENV=production (vedi preset starter)
ALLOW_SQLITE_IN_PRODUCTION=true
SUPABASE_SYNC_ENABLED=false
EVENT_SYNC_SINK=NONE

# --- Monitoring ----------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DAILY_REPORT_AUTO_ENABLED=true
DAILY_REPORT_HOUR=20

# --- Dashboard (localhost) --------------------------------------------------------------------------
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_API_KEY=

# --- SalesNav: OFF (superficie ridotta al minimo) -----------------------------------------------------
SALESNAV_SYNC_ENABLED=false
# Lo scraping SSI richiede Sales Navigator: senza, OFF
SSI_DYNAMIC_LIMITS_ENABLED=false
