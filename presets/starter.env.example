# ============================================================================
# PRESET: STARTER — 1 account, tutto locale, ~$50/mese (proxy escluso: IP casa)
# ============================================================================
# Uso: copia questo file come `.env` nella root del progetto e compila i
# campi segreti vuoti (TELEGRAM_*, DASHBOARD_API_KEY). Le variabili NON
# elencate qui restano sui default di codice (src/config/domains.ts) +
# profilo `production` (src/config/profiles.ts).
# Ogni variabile esiste in src/config/ (verificato alla fonte, goal preset-profili).
# Doc completa e combinazioni VIETATE: docs/PRESET_PROFILES.md
#
# Per chi: primo bot, account LinkedIn personale maturo, PC locale acceso
# nelle ore lavorative, zero costi cloud (AI locale Ollama, SQLite).
# ============================================================================

# --- Profilo base -----------------------------------------------------------
# production = tutti i gate di compliance/anti-ban ATTIVI (mai 'dev' su account reale)
CONFIG_PROFILE=production
TIMEZONE=Europe/Rome
# Headed (finestra visibile): meno superficie di detection del headless e
# permette di seguire login/checkpoint a vista sul PC locale.
HEADLESS=false
# chromium = default, zero setup extra. Upgrade stealth: vedi preset max-stealth.
BROWSER_ENGINE=chromium
BROWSER_LOCALE=it-IT

# --- Orari (sessioni credibili) ----------------------------------------------
HOUR_START=9
HOUR_END=18

# --- Volumi CONSERVATIVI (account singolo, niente fretta) --------------------
SOFT_INVITE_CAP=8
HARD_INVITE_CAP=12
WEEKLY_INVITE_LIMIT=40
SOFT_MSG_CAP=10
HARD_MSG_CAP=15
WEEKLY_MESSAGE_LIMIT=60
PROFILE_VIEW_DAILY_CAP=50
LIKE_DAILY_CAP=20
FOLLOW_DAILY_CAP=8

# --- Crescita graduale (primo periodo col bot) --------------------------------
# Imposta WARMUP_START_DATE alla data del PRIMO avvio (YYYY-MM-DD): i volumi
# crescono gradualmente con pattern credibile.
WARMUP_ENABLED=true
WARMUP_START_DATE=
RAMPUP_ENABLED=true
GROWTH_MODEL_ENABLED=true

# --- AI: tutto locale, $0 (Ollama) -------------------------------------------
# auto + nessuna chiave cloud = Ollama locale per tutto (lead inclusi: zero-PII
# verso cloud by-design). Richiede Ollama installato: https://ollama.com
AI_PROVIDER=auto
OLLAMA_ENDPOINT=http://127.0.0.1:11434
AI_MODEL=llama3.1:8b
AI_PERSONALIZATION_ENABLED=true
AI_SENTIMENT_ENABLED=false
INBOX_AUTO_REPLY_ENABLED=false
AI_ALLOW_REMOTE_ENDPOINT=false
VISION_ALLOW_CLOUD=false

# --- Messaggi / inviti --------------------------------------------------------
# Invito SENZA nota: meno segnali testuali, accept-rate spesso migliore
INVITE_WITH_NOTE=false
WITHDRAW_INVITES_ENABLED=true
PENDING_INVITE_MAX_DAYS=30

# --- DB / storage: SQLite locale ----------------------------------------------
# DB_PATH default: data/linkedin_bot.sqlite — nessun servizio esterno.
# Il flag sotto è OBBLIGATORIO se avvii con NODE_ENV=production (PM2/servizio):
# senza, il boot blocca SQLite (doppia guardia db.ts + validation).
ALLOW_SQLITE_IN_PRODUCTION=true
SUPABASE_SYNC_ENABLED=false
EVENT_SYNC_SINK=NONE

# --- Proxy: NESSUNO (IP di casa) ----------------------------------------------
# Con 1 account a volumi bassi l'IP residenziale di casa è coerente e gratuito.
# NON usare VPN datacenter/Tor: IP flaggati = ban (vedi docs/PRESET_PROFILES.md).

# --- Monitoring / report -------------------------------------------------------
# Telegram consigliato: alert e report giornaliero. Crea il bot con @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DAILY_REPORT_AUTO_ENABLED=true
DAILY_REPORT_HOUR=20

# --- Dashboard (localhost) -----------------------------------------------------
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_API_KEY=

# --- SalesNav: OFF (costo evitato, ricerca normale) ----------------------------
SALESNAV_SYNC_ENABLED=false
# Lo scraping SSI richiede Sales Navigator: senza, meglio OFF (eviti fallback statico)
SSI_DYNAMIC_LIMITS_ENABLED=false
