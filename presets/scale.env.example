# ============================================================================
# PRESET: SCALE — 2 account, VPS, Postgres, monitoring completo
# ============================================================================
# Uso: copia come `.env` e compila i segreti. Le variabili non elencate
# restano sui default di codice (src/config/domains.ts) + profilo `production`.
# Ogni variabile esiste in src/config/ (verificato alla fonte).
# Doc completa e combinazioni VIETATE: docs/PRESET_PROFILES.md
#
# Per chi: agenzia/power-user con 2 account LinkedIn su VPS sempre acceso.
# NOTA ARCHITETTURA: il runtime supporta MAX 2 slot account per istanza
# (src/config/index.ts:20-23). Per N>2 account: N/2 istanze isolate, una per
# coppia, ciascuna con proxy/sessioni/DB propri (mai condividere proxy tra account).
# ============================================================================

# --- Profilo base -----------------------------------------------------------
CONFIG_PROFILE=production
TIMEZONE=Europe/Rome
# VPS senza display: headless + camoufox (stealth che regge l'headless)
HEADLESS=true
BROWSER_ENGINE=camoufox
CAMOUFOX_GEOIP=true
CAMOUFOX_HUMANIZE=true
CAMOUFOX_BLOCK_WEBRTC=true
BROWSER_LOCALE=it-IT

# --- Orari ---------------------------------------------------------------------
HOUR_START=9
HOUR_END=18

# --- Volumi: i cap qui sotto sono GLOBALI (somma dei 2 account) -----------------
# ⚠️ Limite noto: WEEKLY_INVITE_LIMIT è un budget cluster, non per-account —
# un account molto attivo può consumare la quota dell'altro. La ripartizione
# si governa con ACCOUNT_*_INVITE_WEIGHT qui sotto. Tenere il totale ≤ 2×40.
SOFT_INVITE_CAP=12
HARD_INVITE_CAP=18
WEEKLY_INVITE_LIMIT=80
SOFT_MSG_CAP=16
HARD_MSG_CAP=24
WEEKLY_MESSAGE_LIMIT=120
PROFILE_VIEW_DAILY_CAP=80
LIKE_DAILY_CAP=30
FOLLOW_DAILY_CAP=12

# --- ACCOUNT 1 (maturo, pieno regime) -------------------------------------------
# Ogni account DEVE avere il SUO proxy (mai condiviso) e la SUA session dir.
ACCOUNT_1_ID=account1
ACCOUNT_1_SESSION_DIR=data/session-account1
ACCOUNT_1_PROXY_URL=
ACCOUNT_1_PROXY_USERNAME=
ACCOUNT_1_PROXY_PASSWORD=
ACCOUNT_1_PROXY_TYPE=residential
ACCOUNT_1_INVITE_WEIGHT=1.0
ACCOUNT_1_MESSAGE_WEIGHT=1.0

# --- ACCOUNT 2 (esempio: più nuovo → warm-up attivo e peso ridotto) --------------
ACCOUNT_2_ID=account2
ACCOUNT_2_SESSION_DIR=data/session-account2
ACCOUNT_2_PROXY_URL=
ACCOUNT_2_PROXY_USERNAME=
ACCOUNT_2_PROXY_PASSWORD=
ACCOUNT_2_PROXY_TYPE=residential
ACCOUNT_2_INVITE_WEIGHT=0.5
ACCOUNT_2_MESSAGE_WEIGHT=0.5
ACCOUNT_2_WARMUP_ENABLED=true
ACCOUNT_2_WARMUP_START_DATE=
ACCOUNT_2_WARMUP_MAX_DAYS=30

MULTI_ACCOUNT_ENABLED=true

# --- DB: Postgres (VPS/managed) ---------------------------------------------------
# DATABASE_URL pieno = Postgres; lasciare ALLOW_SQLITE_IN_PRODUCTION=false.
DATABASE_URL=
ALLOW_SQLITE_IN_PRODUCTION=false

# --- Sync / control plane -----------------------------------------------------------
SUPABASE_SYNC_ENABLED=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONTROL_PLANE_ENABLED=true
EVENT_SYNC_SINK=SUPABASE

# --- AI ibrida (come pro) -------------------------------------------------------------
AI_PROVIDER=auto
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5-20251001
OLLAMA_ENDPOINT=http://127.0.0.1:11434
AI_MODEL=llama3.1:8b
AI_PERSONALIZATION_ENABLED=true
AI_SENTIMENT_ENABLED=true
INBOX_AUTO_REPLY_ENABLED=false
AI_ALLOW_REMOTE_ENDPOINT=false
VISION_ALLOW_CLOUD=false

# --- SalesNav --------------------------------------------------------------------------
SALESNAV_SYNC_ENABLED=true
SALESNAV_SYNC_MAX_PAGES=3
SALESNAV_SYNC_INTERVAL_HOURS=24
SALESNAV_SYNC_LIMIT=30

# --- Monitoring completo (VPS = osservabilità obbligatoria) ------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DAILY_REPORT_AUTO_ENABLED=true
DAILY_REPORT_HOUR=20
# /metrics protetto da Bearer token (endpoint esposto su VPS)
METRICS_AUTH_TOKEN=
# Canali alert team opzionali (wired sugli incidenti CRITICAL/WARNING)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# --- Dashboard (esposta su VPS: auth obbligatoria) -----------------------------------------
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_API_KEY=
DASHBOARD_TRUSTED_IPS=

# --- Messaggi / inviti ------------------------------------------------------------------
INVITE_WITH_NOTE=false
WITHDRAW_INVITES_ENABLED=true
PENDING_INVITE_MAX_DAYS=30
MESSAGE_SCHEDULE_MIN_DELAY_HOURS=1
MESSAGE_SCHEDULE_MAX_DELAY_HOURS=12
