{
  "name": "linkedin",
  "version": "2.0.0-beta.1",
  "description": "LinkedIn B2B outreach automation platform with stealth browser, risk engine, AI guardian, and drip campaigns",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p tsconfig.json",
    "build:frontend": "ts-node scripts/buildFrontend.ts",
    "lint": "eslint src/**/*.ts --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"public/**/*.{html,css}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"public/**/*.{html,css}\"",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "tsc -p tsconfig.json --noEmit",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json --noEmit",
    "conta-problemi": "npm run typecheck && npm run lint && npm run test:vitest",
    "pre-modifiche": "npm run conta-problemi",
    "post-modifiche": "npm run conta-problemi",
    "helper-manuali": "echo 'Esegui le correzioni manuali come da policy'",
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "daemon:start": "pm2 start ecosystem.config.cjs",
    "daemon:stop": "pm2 stop linkedin-bot-daemon",
    "daemon:logs": "pm2 logs linkedin-bot-daemon",
    "daemon:status": "pm2 status",
    "dashboard": "node dist/index.js dashboard",
    "dashboard:dev": "ts-node src/index.ts dashboard",
    "create-profile": "node dist/index.js create-profile",
    "kpi": "node dist/index.js kpi",
    "ramp-up": "node dist/scripts/rampUp.js",
    "db:backup": "node dist/scripts/backupDb.js",
    "db:restore": "node dist/scripts/restoreDb.js",
    "db:restore:drill": "node dist/scripts/restoreDb.js --drill",
    "db:migrate": "ts-node scripts/migrate-to-postgres.ts",
    "security:advisor": "ts-node src/scripts/securityAdvisor.ts",
    "ai:quality": "ts-node src/scripts/aiQualityPipeline.ts",
    "feature-store": "ts-node src/index.ts feature-store",
    "secrets:rotate": "ts-node src/scripts/rotateSecrets.ts --interval-days 7",
    "security:scan": "node scripts/security/check-no-secrets.mjs",
    "setup:git-hooks": "git config core.hooksPath .githooks",
    "docs": "typedoc --entryPointStrategy expand src --out docs --exclude '**/*.test.ts' --name 'LinkedIn Bot API'",
    "docs:config": "node scripts/generate-config-docs.mjs",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:vitest:coverage": "vitest run --coverage",
    "audit": "ts-node src/scripts/codebaseAudit.ts",
    "audit:json": "ts-node src/scripts/codebaseAudit.ts --json",
    "audit:hooks": "ts-node src/scripts/hooksConformityAudit.ts",
    "audit:handoff-staleness": "ts-node src/scripts/handoffStalenessAudit.ts",
    "audit:miss-metrics": "ts-node src/scripts/missMetricsAudit.ts",
    "audit:skill-duplicates": "ts-node src/scripts/skillDuplicatesAudit.ts",
    "audit:memory-staleness": "ts-node src/scripts/memoryStalenessAudit.ts",
    "audit:docs-size": "ts-node src/scripts/docsSizeAudit.ts",
    "audit:weekly": "npm run audit:miss-metrics && npm run audit:handoff-staleness && npm run audit:continuation-completeness && npm run audit:violations && npm run audit:memory-staleness && npm run audit:docs-size && npm run audit:output-styles && npm run audit:mcp-config && npm run audit:json-schemas && npm run audit:rules-coverage && npm run audit:skill-filenames",
    "audit:monthly": "npm run audit:ai-control-plane && npm run audit:rule-enforcement && npm run audit:ledger && npm run audit:skills",
    "audit:ai-control-plane": "npm run audit:ai-control-plane:docs && npm run audit:ai-reasoning-hardening && npm run audit:hooks && npm run audit:routing && npm run audit:adk-capabilities && npm run audit:l2-l6 && npm run audit:ai-list-completeness",
    "audit:ai-control-plane:docs": "ts-node src/scripts/aiControlPlaneAudit.ts",
    "audit:ai-reasoning-hardening": "ts-node src/scripts/aiReasoningHardeningAudit.ts",
    "audit:orchestrator-contract": "ts-node src/scripts/aiReasoningHardeningAudit.ts --scope=orchestrator",
    "audit:reasoning-trace": "ts-node src/scripts/aiReasoningHardeningAudit.ts --scope=reasoning",
    "audit:hook-semantic-coverage": "ts-node src/scripts/aiReasoningHardeningAudit.ts --scope=hook-coverage",
    "audit:continuation-completeness": "ts-node src/scripts/aiReasoningHardeningAudit.ts --scope=continuation",
    "audit:codex-hook-parity": "ts-node src/scripts/aiReasoningHardeningAudit.ts --scope=codex",
    "audit:ai-list-completeness": "ts-node src/scripts/aiListCompletenessAudit.ts",
    "audit:output-styles": "ts-node src/scripts/outputStylesAudit.ts",
    "audit:mcp-config": "ts-node src/scripts/mcpConfigAudit.ts",
    "audit:git-automation": "ts-node src/scripts/gitAutomationAudit.ts",
    "audit:git-automation:json": "ts-node src/scripts/gitAutomationAudit.ts --json",
    "audit:git-automation:strict:commit": "ts-node src/scripts/gitAutomationAudit.ts --strict=commit",
    "audit:git-automation:strict:push": "ts-node src/scripts/gitAutomationAudit.ts --strict=push",
    "audit:routing": "ts-node src/scripts/capabilityRoutingAudit.ts",
    "audit:json-schemas": "ts-node src/scripts/jsonSchemasAudit.ts",
    "audit:rules-coverage": "ts-node src/scripts/rulesCoverageAudit.ts",
    "audit:skill-filenames": "ts-node src/scripts/skillFilenameAudit.ts",
    "audit:adk-capabilities": "ts-node src/scripts/adkCapabilityGovernanceAudit.ts",
    "audit:l2-l6": "ts-node src/scripts/levelEnforcementAudit.ts",
    "audit:rule-enforcement": "ts-node src/scripts/ruleEnforcementMatrix.ts",
    "audit:violations": "ts-node src/scripts/violationLogAnalysis.ts",
    "audit:ledger": "ts-node src/scripts/ledgerCoverageAudit.ts",
    "audit:skills": "ts-node src/scripts/skillActivationAudit.ts",
    "test:e2e:dry": "ts-node src/tests/e2eDry.ts",
    "test:a11y:smoke": "ts-node src/tests/accessibilitySmoke.ts",
    "test": "npm run test:vitest && npm run test:e2e:dry && npm run test:a11y:smoke",
    "docker:build": "bash scripts/docker-release.sh build",
    "docker:promote": "bash scripts/docker-release.sh promote",
    "docker:rollback": "bash scripts/docker-release.sh rollback",
    "docker:list": "bash scripts/docker-release.sh list"
  },
  "keywords": [],
  "author": "Private",
  "license": "UNLICENSED",
  "type": "commonjs",
  "dependencies": {
    "@sentry/node": "^10.46.0",
    "@supabase/supabase-js": "^2.100.1",
    "camoufox-js": "^0.9.3",
    "chart.js": "^4.5.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "cycletls": "^2.0.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "inquirer": "^8.2.7",
    "libphonenumber-js": "^1.12.41",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "pm2": "^6.0.14",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/inquirer": "^8.2.12",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/sqlite3": "^3.1.11",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.1.6",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "node-gyp": "^11.5.0",
    "tar": "^7.5.8",
    "minimatch": "^10.2.2"
  }
}
