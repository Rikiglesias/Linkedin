                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:/Users/albie/Desktop/Programmi/Linkedin/.codex/hooks/codex-stop-check.ps1\"",
                        "timeout": 10,
                        "statusMessage": "Checking Codex stop gate"
                    }
                ]
            }
        ]
    }
}
